<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Us: The Deck 💌</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --pink:#d63384;--pink-l:#f9a8d4;--pink-ll:#fdf2f8;
  --blue:#2563eb;--amber:#d97706;--teal:#0d9488;--purple:#7c3aed;
  --gray:#6b7280;--dark:#1e1b4b;
  --memory-bg:#fdf2f8;--memory-b:#f9a8d4;--memory-t:#9d174d;
  --duel-bg:#eff6ff;--duel-b:#93c5fd;--duel-t:#1e40af;
  --luck-bg:#fffbeb;--luck-b:#fcd34d;--luck-t:#92400e;
  --shield-bg:#f0fdfa;--shield-b:#5eead4;--shield-t:#134e4a;
  --wild-bg:#f5f3ff;--wild-b:#c4b5fd;--wild-t:#4c1d95;
}
html,body{height:100%;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--pink-ll);color:var(--dark);overflow:hidden}

/* ── Screens ── */
.screen{display:none;flex-direction:column;align-items:center;justify-content:center;height:100dvh;padding:24px;gap:16px}
.screen.active{display:flex}

/* ── Home ── */
#screen-home .logo{font-size:52px}
#screen-home h1{font-size:26px;font-weight:700;color:var(--dark);margin-top:-4px}
#screen-home .tagline{font-size:14px;color:var(--gray);text-align:center;margin-bottom:4px}
.divider{display:flex;align-items:center;gap:12px;width:100%;max-width:320px;color:#c4b5fd;font-size:13px}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:#e9d5ff}
input[type=text]{width:100%;max-width:320px;height:48px;border:1.5px solid var(--pink-l);border-radius:12px;padding:0 16px;font-size:16px;outline:none;background:#fff;color:var(--dark);transition:border-color .2s}
input[type=text]:focus{border-color:var(--pink)}
input[type=text]::placeholder{color:#c084fc}
.btn{width:100%;max-width:320px;height:50px;border:none;border-radius:12px;font-size:16px;font-weight:700;cursor:pointer;transition:transform .12s,opacity .2s}
.btn:active{transform:scale(.96)}
.btn-primary{background:linear-gradient(135deg,var(--pink),#a855f7);color:#fff;box-shadow:0 4px 20px rgba(214,51,132,.3)}
.btn-secondary{background:#fff;border:1.5px solid var(--pink);color:var(--pink)}
.err-msg{color:#dc2626;font-size:13px;text-align:center;min-height:18px;max-width:320px}

/* ── Lobby ── */
#screen-lobby{background:linear-gradient(160deg,#fdf2f8 60%,#f3e8ff)}
.code-box{background:#fff;border:2px dashed var(--pink-l);border-radius:20px;padding:24px 36px;text-align:center;cursor:pointer;transition:background .2s;box-shadow:0 4px 24px rgba(214,51,132,.08)}
.code-box:active{background:#fce7f3}
.code-label{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gray);margin-bottom:6px}
.code-val{font-size:46px;font-weight:800;color:var(--pink);letter-spacing:.18em;line-height:1}
.code-hint{font-size:11px;color:#c084fc;margin-top:6px}
.status-badge{background:#fff;border:1.5px solid var(--pink-l);border-radius:20px;padding:10px 22px;font-size:14px;color:var(--gray);box-shadow:0 2px 12px rgba(0,0,0,.05)}
.status-badge.ready{background:linear-gradient(135deg,#fce7f3,#f3e8ff);border-color:var(--pink);color:var(--dark);font-weight:600}

/* ── Game Board ── */
#screen-game{display:none;flex-direction:column;padding:0;gap:0;height:100dvh;justify-content:space-between}
#screen-game.active{display:flex}
.op-area{background:linear-gradient(135deg,#1e1b4b,#2d1b69);color:#fff;padding:14px 20px;padding-top:max(14px,env(safe-area-inset-top));display:flex;justify-content:space-between;align-items:center}
.op-name{font-size:15px;font-weight:600;display:flex;align-items:center;gap:6px}
.op-meta{font-size:12px;color:#c4b5fd;margin-top:2px}
.op-score-val{font-size:26px;font-weight:800;color:#f9a8d4}
.shield-pip{font-size:14px;animation:shieldPulse 1.5s ease-in-out infinite}
@keyframes shieldPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.2)}}

.center-area{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;padding:12px}
.deck-area{display:flex;align-items:center;gap:14px}
.deck-pile{width:64px;height:88px;background:linear-gradient(135deg,#1e1b4b,#7c3aed);border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;box-shadow:4px 4px 0 rgba(0,0,0,.18)}
.deck-count{font-size:20px;font-weight:700;color:#fff}
.deck-lbl{font-size:9px;color:#c4b5fd;letter-spacing:.08em;text-transform:uppercase;margin-top:2px}
.score-widget{text-align:center;min-width:80px}
.sw-score{font-size:32px;font-weight:800}
.sw-label{font-size:11px;color:var(--gray);text-transform:uppercase;letter-spacing:.06em}
.vs-divider{font-size:18px;color:#d1d5db;font-weight:700}

.turn-banner{background:#fff;border:1.5px solid var(--pink-l);border-radius:22px;padding:9px 22px;font-size:14px;font-weight:600;color:var(--dark);text-align:center;box-shadow:0 2px 12px rgba(0,0,0,.05)}
.turn-banner.my-turn{background:linear-gradient(135deg,#fce7f3,#f3e8ff);border-color:var(--pink);color:var(--pink);animation:pulse 1.8s ease-in-out infinite}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(214,51,132,.25)}50%{box-shadow:0 0 0 8px rgba(214,51,132,0)}}

.progress-wrap{width:100%;max-width:280px}
.progress-labels{display:flex;justify-content:space-between;font-size:11px;color:var(--gray);margin-bottom:4px}
.progress-track{height:10px;background:#e9d5ff;border-radius:5px;overflow:hidden;display:flex}
.prog-me{height:100%;background:linear-gradient(90deg,var(--pink),#a855f7);border-radius:5px 0 0 5px;transition:width .5s}
.prog-op{height:100%;background:linear-gradient(90deg,#6366f1,#2563eb);border-radius:0 5px 5px 0;transition:width .5s;margin-left:auto}

.my-area{background:#fff;border-top:1px solid var(--pink-l);padding:12px 16px;padding-bottom:max(12px,env(safe-area-inset-bottom))}
.my-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.my-name-chip{font-size:14px;font-weight:700;color:var(--dark);display:flex;align-items:center;gap:5px}
.my-score-big{font-size:26px;font-weight:800;color:var(--pink);display:flex;align-items:baseline;gap:3px}
.pts-label{font-size:11px;color:var(--gray);font-weight:400}

.hand{display:flex;gap:8px;overflow-x:auto;padding:4px 0 2px;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.hand::-webkit-scrollbar{display:none}
.card{flex-shrink:0;width:84px;height:116px;border-radius:12px;border:2px solid transparent;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 6px;cursor:pointer;transition:transform .15s,box-shadow .15s;user-select:none;text-align:center;position:relative}
.card.selected{transform:translateY(-16px);box-shadow:0 10px 28px rgba(0,0,0,.2)}
.card-icon{font-size:26px;margin-bottom:4px;line-height:1}
.card-name{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px}
.card-desc{font-size:9px;line-height:1.3;opacity:.75}
.card.memory{background:var(--memory-bg);border-color:var(--memory-b);color:var(--memory-t)}
.card.duel{background:var(--duel-bg);border-color:var(--duel-b);color:var(--duel-t)}
.card.luck{background:var(--luck-bg);border-color:var(--luck-b);color:var(--luck-t)}
.card.shield{background:var(--shield-bg);border-color:var(--shield-b);color:var(--shield-t)}
.card.wild{background:var(--wild-bg);border-color:var(--wild-b);color:var(--wild-t)}
.card.disabled{opacity:.45;cursor:default;transform:none !important}
#play-wrap{height:38px;display:flex;align-items:center;justify-content:center;margin-top:4px}
#play-btn{background:linear-gradient(135deg,var(--pink),#a855f7);color:#fff;border:none;border-radius:22px;padding:9px 36px;font-size:15px;font-weight:700;cursor:pointer;display:none;box-shadow:0 4px 16px rgba(214,51,132,.3);transition:transform .12s}
#play-btn:active{transform:scale(.95)}

/* ── Overlay ── */
#overlay{position:fixed;inset:0;z-index:200;display:none;flex-direction:column;align-items:center;justify-content:center;padding:16px;background:rgba(253,242,248,.96);backdrop-filter:blur(8px)}
#overlay.show{display:flex;animation:ovIn .22s ease}
@keyframes ovIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.ov-box{background:#fff;border:1px solid var(--pink-l);border-radius:22px;padding:26px 22px;width:100%;max-width:380px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:12px;box-shadow:0 8px 40px rgba(214,51,132,.12)}
.ov-icon{font-size:48px;line-height:1}
.ov-title{font-size:20px;font-weight:800;color:var(--dark)}
.ov-sub{font-size:13px;color:var(--gray);line-height:1.5}
.ov-question{font-size:15px;font-weight:600;color:var(--dark);line-height:1.45;background:var(--pink-ll);border-radius:12px;padding:16px;width:100%}
.ov-hint{font-size:12px;color:var(--gray);font-style:italic}
.ov-answer-wrap{width:100%;text-align:left}
.ov-answer-lbl{font-size:11px;font-weight:700;color:var(--pink);margin-bottom:6px;text-transform:uppercase;letter-spacing:.06em}
.ov-answer-text{font-size:14px;color:var(--dark);background:var(--pink-ll);border-radius:10px;padding:12px;line-height:1.5}
textarea{width:100%;border:1.5px solid var(--pink-l);border-radius:10px;padding:12px;font-size:14px;font-family:inherit;resize:none;outline:none;background:#fff;transition:border-color .2s}
textarea:focus{border-color:var(--pink)}
.judge-row{display:flex;gap:10px;width:100%}
.btn-ok{flex:1;height:50px;background:#dcfce7;border:1.5px solid #86efac;color:#166534;font-size:14px;font-weight:700;border-radius:12px;cursor:pointer;transition:background .12s}
.btn-ok:active{background:#bbf7d0}
.btn-no{flex:1;height:50px;background:#fef2f2;border:1.5px solid #fca5a5;color:#991b1b;font-size:14px;font-weight:700;border-radius:12px;cursor:pointer;transition:background .12s}
.btn-no:active{background:#fee2e2}
.ov-btn{width:100%;height:48px;background:linear-gradient(135deg,var(--pink),#a855f7);border:none;border-radius:12px;color:#fff;font-size:15px;font-weight:700;cursor:pointer;transition:transform .12s}
.ov-btn:active{transform:scale(.96)}
.result-badge{font-size:15px;font-weight:700;border-radius:12px;padding:12px 20px;width:100%}
.rb-win{background:#dcfce7;color:#166534}
.rb-loss{background:#fef2f2;color:#991b1b}
.rb-tie{background:#fef3c7;color:#92400e}
.rb-info{background:#f0f9ff;color:#0c4a6e}

/* ── Dice ── */
.dice-wrap{position:relative;margin:4px 0}
.dice{font-size:80px;line-height:1;display:block;transition:transform .1s}
.dice.rolling{animation:diceRoll .12s linear infinite}
@keyframes diceRoll{0%{transform:rotate(-8deg) scale(.95)}50%{transform:rotate(8deg) scale(1.05)}100%{transform:rotate(-8deg) scale(.95)}}
.luck-result{font-size:16px;font-weight:700;border-radius:12px;padding:12px 18px;width:100%;animation:popIn .3s cubic-bezier(.34,1.56,.64,1)}
@keyframes popIn{from{transform:scale(.6);opacity:0}to{transform:scale(1);opacity:1}}
.lr-pos{background:#dcfce7;color:#166534}
.lr-neg{background:#fef2f2;color:#991b1b}
.lr-neu{background:#fef3c7;color:#92400e}

/* ── Shield Blast ── */
.shield-blast-wrap{display:flex;flex-direction:column;align-items:center;gap:8px;width:100%}
.shield-big{font-size:72px;animation:shieldBlast .4s cubic-bezier(.34,1.56,.64,1)}
@keyframes shieldBlast{0%{transform:scale(0) rotate(-20deg)}60%{transform:scale(1.2) rotate(5deg)}100%{transform:scale(1) rotate(0deg)}}
.shield-type-badge{font-size:22px;font-weight:800;padding:6px 20px;border-radius:20px;background:var(--shield-bg);color:var(--shield-t);border:1.5px solid var(--shield-b);animation:popIn .3s .15s cubic-bezier(.34,1.56,.64,1) both}
.shield-effect{font-size:14px;font-weight:600;color:var(--dark);background:#f0fdfa;border-radius:10px;padding:12px;width:100%;animation:popIn .3s .3s cubic-bezier(.34,1.56,.64,1) both}
.shield-set-desc{font-size:13px;color:var(--gray);background:var(--shield-bg);border-radius:10px;padding:12px;width:100%;line-height:1.4}

/* ── RPS ── */
.rps-phase-pick .rps-row{display:flex;gap:14px;justify-content:center}
.rps-btn{width:84px;height:84px;font-size:38px;background:#fff;border:2px solid var(--pink-l);border-radius:18px;cursor:pointer;transition:background .12s,border-color .12s,transform .1s;display:flex;align-items:center;justify-content:center}
.rps-btn:active{transform:scale(.88)}
.rps-btn.chosen{background:#fce7f3;border-color:var(--pink);transform:scale(1.06)}
.rps-waiting{font-size:13px;color:var(--gray);animation:fadeInOut 1.5s ease-in-out infinite}
@keyframes fadeInOut{0%,100%{opacity:.5}50%{opacity:1}}
.rps-countdown{font-size:72px;font-weight:900;color:var(--pink);line-height:1;animation:countPop .25s cubic-bezier(.34,1.56,.64,1)}
@keyframes countPop{from{transform:scale(.5);opacity:0}to{transform:scale(1);opacity:1}}
.rps-vs-row{display:flex;align-items:center;justify-content:center;gap:16px;width:100%}
.rps-player-col{display:flex;flex-direction:column;align-items:center;gap:6px;flex:1}
.rps-choice-reveal{font-size:60px;animation:revealSlide .3s cubic-bezier(.34,1.56,.64,1)}
@keyframes revealSlide{from{transform:scale(.3) rotateY(90deg);opacity:0}to{transform:scale(1) rotateY(0deg);opacity:1}}
.rps-player-name{font-size:12px;color:var(--gray);font-weight:600}
.rps-vs-label{font-size:22px;font-weight:800;color:#d1d5db}
.rps-winner-glow{filter:drop-shadow(0 0 12px rgba(214,51,132,.6))}

/* ── Tug of War ── */
.tug-header{display:flex;justify-content:space-between;width:100%;font-size:12px;font-weight:700;color:var(--gray)}
.tug-scene{width:100%;position:relative;height:64px;display:flex;align-items:center}
.tug-rope{width:100%;height:10px;background:linear-gradient(90deg,#fce7f3,#ddd6fe);border-radius:5px;position:relative;overflow:visible}
.tug-knot{width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,var(--pink),#a855f7);border:3px solid #fff;box-shadow:0 3px 12px rgba(214,51,132,.45);position:absolute;top:50%;transform:translate(-50%,-50%);transition:left .08s;display:flex;align-items:center;justify-content:center;font-size:12px;z-index:2}
.tug-zone-me{position:absolute;left:0;top:0;height:100%;background:rgba(214,51,132,.12);border-radius:5px 0 0 5px;transition:width .08s}
.tug-zone-op{position:absolute;right:0;top:0;height:100%;background:rgba(99,102,241,.12);border-radius:0 5px 5px 0;transition:width .08s}
.tug-players-row{display:flex;justify-content:space-between;width:100%;align-items:center}
.tug-player-info{display:flex;flex-direction:column;align-items:center;gap:2px}
.tug-player-name{font-size:11px;font-weight:700;color:var(--dark)}
.tug-clicks{font-size:22px;font-weight:800;color:var(--pink);line-height:1}
.tug-clicks.op{color:#6366f1}
.tug-timer-ring{width:64px;height:64px;position:relative;display:flex;align-items:center;justify-content:center}
.tug-timer-svg{position:absolute;inset:0;transform:rotate(-90deg)}
.tug-timer-bg{fill:none;stroke:#e9d5ff;stroke-width:4}
.tug-timer-arc{fill:none;stroke:var(--pink);stroke-width:4;stroke-linecap:round;stroke-dasharray:163;stroke-dashoffset:0;transition:stroke-dashoffset .5s linear}
.tug-timer-num{font-size:22px;font-weight:800;color:var(--pink);z-index:1}
.tug-pull-btn{width:100%;height:70px;background:linear-gradient(135deg,var(--pink),#a855f7);border:none;border-radius:18px;font-size:22px;font-weight:800;color:#fff;cursor:pointer;box-shadow:0 6px 24px rgba(214,51,132,.35);transition:transform .08s;user-select:none;-webkit-tap-highlight-color:transparent;letter-spacing:.04em}
.tug-pull-btn:active{transform:scale(.94)}
.tug-pull-btn:disabled{background:#d1d5db;box-shadow:none;transform:none}
.tug-end-result{width:100%}

/* ── Wild ── */
.wild-effect{font-size:14px;font-weight:600;color:var(--purple);background:#f5f3ff;border-radius:12px;padding:14px;width:100%;line-height:1.5}
.peek-hand{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;padding:4px 0}
.mini-card{border-radius:8px;padding:8px 10px;font-size:12px;font-weight:600;display:flex;align-items:center;gap:4px;border:1.5px solid transparent}
.mini-card.memory{background:var(--memory-bg);border-color:var(--memory-b);color:var(--memory-t)}
.mini-card.duel{background:var(--duel-bg);border-color:var(--duel-b);color:var(--duel-t)}
.mini-card.luck{background:var(--luck-bg);border-color:var(--luck-b);color:var(--luck-t)}
.mini-card.shield{background:var(--shield-bg);border-color:var(--shield-b);color:var(--shield-t)}
.mini-card.wild{background:var(--wild-bg);border-color:var(--wild-b);color:var(--wild-t)}
.peek-timer{font-size:30px;font-weight:800;color:var(--pink)}

/* ── Winner ── */
#screen-over{background:linear-gradient(160deg,#1e1b4b,#7c3aed)}
.win-emoji{font-size:52px;animation:winBounce .6s ease-in-out infinite alternate}
@keyframes winBounce{from{transform:translateY(0) scale(1)}to{transform:translateY(-14px) scale(1.1)}}
.win-title{font-size:28px;font-weight:800;color:#fff;text-align:center;line-height:1.2}
.win-sub{font-size:14px;color:#c4b5fd;text-align:center}
.score-cards{display:flex;gap:12px}
.sc{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:16px;padding:16px 22px;text-align:center}
.sc.winner{background:rgba(249,168,212,.2);border-color:var(--pink-l)}
.sc-name{font-size:12px;color:#c4b5fd;margin-bottom:4px}
.sc-val{font-size:36px;font-weight:800;color:#fff}
.btn-again{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);border-radius:14px;color:#fff;font-size:15px;font-weight:700;padding:14px 38px;cursor:pointer;transition:background .2s}
.btn-again:active{background:rgba(255,255,255,.28)}

/* ── Toast ── */
#toast{position:fixed;bottom:max(28px,env(safe-area-inset-bottom));left:50%;transform:translateX(-50%);background:#1e1b4b;color:#fff;border-radius:22px;padding:10px 22px;font-size:13px;z-index:500;display:none;max-width:90vw;text-align:center}
#toast.show{display:block;animation:toastIn .2s ease}
@keyframes toastIn{from{opacity:0;transform:translate(-50%,10px)}to{opacity:1;transform:translate(-50%,0)}}

/* ── Connecting ── */
.spinner{width:34px;height:34px;border:3px solid var(--pink-l);border-top-color:var(--pink);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
</style>
</head>
<body>

<!-- HOME -->
<div id="screen-home" class="screen active">
  <div class="logo">💌</div>
  <h1>Us: The Deck</h1>
  <p class="tagline">A card game built around your love story</p>
  <input id="name-in" type="text" placeholder="Your name..." maxlength="20" autocomplete="off">
  <button class="btn btn-primary" id="create-btn">Create Room</button>
  <div class="divider">or join with a code</div>
  <input id="code-in" type="text" placeholder="Room code..." maxlength="4" style="text-transform:uppercase;letter-spacing:.12em;text-align:center" autocomplete="off">
  <button class="btn btn-secondary" id="join-btn">Join Room</button>
  <p class="err-msg" id="home-err"></p>
</div>

<!-- LOBBY -->
<div id="screen-lobby" class="screen">
  <div class="logo">💌</div>
  <p style="font-size:14px;color:var(--gray)">Share this code with your partner</p>
  <div class="code-box" onclick="copyCode()">
    <div class="code-label">Room Code</div>
    <div class="code-val" id="code-disp">----</div>
    <div class="code-hint">tap to copy 📋</div>
  </div>
  <div class="status-badge" id="lobby-status">⏳ Waiting for your partner...</div>
  <div class="spinner" id="lobby-spin"></div>
</div>

<!-- GAME -->
<div id="screen-game" class="screen">
  <div class="op-area">
    <div>
      <div class="op-name"><span id="op-name">Partner</span><span id="op-shield-pip" class="shield-pip" style="display:none">🛡️</span></div>
      <div class="op-meta" id="op-cards-lbl">? cards</div>
    </div>
    <div style="text-align:right">
      <div style="font-size:10px;color:#c4b5fd;letter-spacing:.08em;text-transform:uppercase;margin-bottom:2px">Score</div>
      <div class="op-score-val" id="op-score">0</div>
    </div>
  </div>

  <div class="center-area">
    <div class="deck-area">
      <div class="score-widget">
        <div class="sw-score" style="color:var(--pink)" id="ctr-my-score">0</div>
        <div class="sw-label" id="ctr-my-name">You</div>
      </div>
      <div class="vs-divider">vs</div>
      <div class="deck-pile"><div class="deck-count" id="deck-left">40</div><div class="deck-lbl">deck</div></div>
      <div class="vs-divider">vs</div>
      <div class="score-widget">
        <div class="sw-score" style="color:#6366f1" id="ctr-op-score">0</div>
        <div class="sw-label" id="ctr-op-name">Them</div>
      </div>
    </div>
    <div class="turn-banner" id="turn-banner">...</div>
    <div class="progress-wrap">
      <div class="progress-labels">
        <span id="p-my">You: 0 pts</span>
        <span style="color:#a78bfa;font-size:11px">First to 10 wins</span>
        <span id="p-op">Them: 0 pts</span>
      </div>
      <div class="progress-track">
        <div class="prog-me" id="prog-me" style="width:0%"></div>
        <div style="flex:1"></div>
        <div class="prog-op" id="prog-op" style="width:0%"></div>
      </div>
    </div>
  </div>

  <div class="my-area">
    <div class="my-row">
      <div class="my-name-chip"><span id="my-name">You</span><span id="my-shield-pip" style="display:none">🛡️</span></div>
      <div class="my-score-big"><span id="my-score">0</span><span class="pts-label">pts</span></div>
    </div>
    <div class="hand" id="hand"></div>
    <div id="play-wrap"><button id="play-btn">Play Card ✨</button></div>
  </div>
</div>

<!-- WINNER -->
<div id="screen-over" class="screen">
  <div class="win-emoji" id="win-emoji">🎉</div>
  <div class="win-title" id="win-title">Winner!</div>
  <div class="win-sub" id="win-sub"></div>
  <div class="score-cards" id="score-cards"></div>
  <button class="btn-again" onclick="location.reload()">Play Again 💌</button>
</div>

<!-- OVERLAY -->
<div id="overlay"><div class="ov-box" id="ov-box"></div></div>

<!-- TOAST -->
<div id="toast"></div>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
let myId = null, roomCode = null, selectedCard = null;
let ovNeedsInput = false, ovPeek = false, peekIv = null;
let tugIv = null, tugEnded = false;

const gs = {
  myIndex: null, myHand: [], myScore: 0, myName: '',
  opName: '', opScore: 0, opCards: 0, deckLeft: 0,
  currentTurn: 0, isMyTurn: false,
  shielded: false, opShielded: false, doubleActive: false
};

// ── Screens ──────────────────────────────────────────────────────────────────
function show(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function showOv(html) {
  document.getElementById('ov-box').innerHTML = html;
  document.getElementById('overlay').classList.add('show');
}
function hideOv() {
  if (ovNeedsInput || ovPeek) return;
  document.getElementById('overlay').classList.remove('show');
}
function forceHide() {
  ovNeedsInput = false; ovPeek = false;
  if (peekIv) { clearInterval(peekIv); peekIv = null; }
  document.getElementById('overlay').classList.remove('show');
}
function toast(msg, dur=2800) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), dur);
}
function copyCode() {
  if (!roomCode) return;
  navigator.clipboard.writeText(roomCode).catch(()=>{});
  toast('Room code copied! 📋');
}
function trunc(s, n) { return s?.length > n ? s.slice(0,n)+'…' : s||''; }

// ── Game render ──────────────────────────────────────────────────────────────
function renderGame() {
  setText('op-name', gs.opName);
  setText('op-score', gs.opScore);
  setText('op-cards-lbl', `${gs.opCards} card${gs.opCards!==1?'s':''}`);
  document.getElementById('op-shield-pip').style.display = gs.opShielded ? '' : 'none';

  setText('my-name', gs.myName);
  setText('my-score', gs.myScore);
  setText('ctr-my-score', gs.myScore);
  setText('ctr-my-name', gs.myName);
  setText('ctr-op-score', gs.opScore);
  setText('ctr-op-name', gs.opName);
  setText('deck-left', gs.deckLeft);
  document.getElementById('my-shield-pip').style.display = gs.shielded ? '' : 'none';

  const mp = Math.min(100, gs.myScore * 10);
  const op = Math.min(100, gs.opScore * 10);
  document.getElementById('prog-me').style.width = mp + '%';
  document.getElementById('prog-op').style.width = op + '%';
  setText('p-my', `You: ${gs.myScore} pts`);
  setText('p-op', `${gs.opName}: ${gs.opScore} pts`);

  const banner = document.getElementById('turn-banner');
  if (gs.isMyTurn) {
    banner.textContent = '✨ Your turn — play a card!';
    banner.className = 'turn-banner my-turn';
  } else {
    banner.textContent = `⏳ ${gs.opName}'s turn...`;
    banner.className = 'turn-banner';
  }
  renderHand();
}

function setText(id, val) {
  const el = document.getElementById(id);
  if (el) el.textContent = val;
}

function renderHand() {
  const wrap = document.getElementById('hand');
  wrap.innerHTML = '';
  gs.myHand.forEach(c => {
    const el = document.createElement('div');
    const isSelected = selectedCard === c.id;
    const isDisabled = !gs.isMyTurn;
    el.className = `card ${c.type}${isSelected?' selected':''}${isDisabled?' disabled':''}`;
    const desc = c.question ? trunc(c.question, 44) : trunc(c.desc || c.subtype || '', 40);
    el.innerHTML = `<div class="card-icon">${c.icon}</div><div class="card-name">${c.name}</div><div class="card-desc">${desc}</div>`;
    if (gs.isMyTurn) el.onclick = () => { selectedCard = isSelected ? null : c.id; renderHand(); updatePlayBtn(); };
    wrap.appendChild(el);
  });
  updatePlayBtn();
}

function updatePlayBtn() {
  const btn = document.getElementById('play-btn');
  btn.style.display = (selectedCard && gs.isMyTurn) ? 'block' : 'none';
}

// ── Socket events ─────────────────────────────────────────────────────────────
socket.on('connect', () => { myId = socket.id; });

socket.on('created', ({ code }) => {
  roomCode = code;
  document.getElementById('code-disp').textContent = code;
  show('screen-lobby');
});

socket.on('err', msg => {
  document.getElementById('home-err').textContent = msg;
  toast('⚠️ ' + msg);
});

socket.on('gamestart', ({ names }) => {
  document.getElementById('lobby-spin').style.display = 'none';
  document.getElementById('lobby-status').innerHTML = `🎉 <strong>${names[0]}</strong> & <strong>${names[1]}</strong> — Game starting!`;
  document.getElementById('lobby-status').className = 'status-badge ready';
  setTimeout(() => show('screen-game'), 800);
});

socket.on('state', data => {
  Object.assign(gs, data);
  if (gs.phase === 'game') {
    renderGame();
    if (!ovNeedsInput && !ovPeek) hideOv();
  }
});

socket.on('played', ({ card, by, byIdx }) => {
  if (byIdx !== gs.myIndex) toast(`${by} played a ${card.name} card!`);
  selectedCard = null; updatePlayBtn();
});

// Memory
socket.on('memoryq', ({ card, askerId, askerName }) => {
  const isAsker = askerId === socket.id;
  ovNeedsInput = true;
  if (isAsker) {
    showOv(`
      <div class="ov-icon">💌</div>
      <div class="ov-title">Memory Card</div>
      <div class="ov-question">"${card.question}"</div>
      <div class="ov-sub" id="ov-wait">⏳ Waiting for ${gs.opName}'s answer...</div>
      <div id="ov-judge" style="display:none;flex-direction:column;gap:10px;width:100%">
        <div class="ov-answer-wrap">
          <div class="ov-answer-lbl">They answered:</div>
          <div class="ov-answer-text" id="ov-ans">...</div>
        </div>
        <div class="judge-row">
          <button class="btn-ok" onclick="doJudge(true)">✓ Correct!<br><small style="opacity:.7">+2 pts to them</small></button>
          <button class="btn-no" onclick="doJudge(false)">✗ Wrong!<br><small style="opacity:.7">+1 pt to me</small></button>
        </div>
      </div>
    `);
  } else {
    showOv(`
      <div class="ov-icon">💌</div>
      <div class="ov-title">Memory Card</div>
      <div class="ov-sub">Question from <strong>${askerName}</strong></div>
      <div class="ov-question">"${card.question}"</div>
      <textarea id="ans-in" rows="2" placeholder="Type your answer..." maxlength="200"></textarea>
      <button class="ov-btn" onclick="submitAns()">Submit Answer</button>
    `);
  }
});

socket.on('memoryanswerreceived', ({ answer }) => {
  const w = document.getElementById('ov-wait');
  const j = document.getElementById('ov-judge');
  const a = document.getElementById('ov-ans');
  if (w) w.style.display = 'none';
  if (a) a.textContent = answer;
  if (j) j.style.display = 'flex';
});

socket.on('memoryjudged', ({ correct, pts, scorerName }) => {
  ovNeedsInput = false;
  showOv(`
    <div class="ov-icon">${correct?'✅':'❌'}</div>
    <div class="ov-title">${correct?'Correct!':'Wrong!'}</div>
    <div class="result-badge ${correct?'rb-win':'rb-loss'}">+${pts} pts → ${scorerName}</div>
  `);
  setTimeout(() => forceHide(), 2600);
});

// Luck
socket.on('luckresolve', ({ card, roll, pd, od, note, playerName, opName }) => {
  const faces = ['','⚀','⚁','⚂','⚃','⚄','⚅'];
  let txt = '', cls = 'lr-neu';
  if (pd > 0) { txt = `+${pd} pt${pd!==1?'s':''} for ${playerName}`; cls='lr-pos'; }
  else if (pd < 0) { txt = `${pd} pt${Math.abs(pd)!==1?'s':''} for ${playerName}`; cls='lr-neg'; }
  else if (od > 0) { txt = `+${od} pt${od!==1?'s':''} for ${opName}`; cls='lr-pos'; }
  else { txt = 'No change this round!'; }
  if (od < 0 && pd >= 0) { txt += ` · −1 pt for ${opName}`; }

  showOv(`
    <div class="ov-icon">🎲</div>
    <div class="ov-title">Luck Card</div>
    <div class="ov-sub">${card.desc}</div>
    <div class="dice-wrap"><span class="dice" id="dice">⚀</span></div>
    <div class="luck-result ${cls}" id="lk-result" style="display:none">${txt}</div>
    ${note ? `<div class="ov-hint">${note}</div>` : ''}
  `);

  let n = 0;
  const el = document.getElementById('dice');
  if (el) el.classList.add('rolling');
  const iv = setInterval(() => {
    if (el) el.textContent = faces[Math.floor(Math.random()*6)+1];
    if (++n >= 16) {
      clearInterval(iv);
      if (el) { el.classList.remove('rolling'); el.textContent = faces[roll]; }
      const r = document.getElementById('lk-result');
      if (r) r.style.display = 'block';
    }
  }, 90);
});

// Shield set
socket.on('shieldset', ({ playerName, card }) => {
  showOv(`
    <div class="shield-blast-wrap">
      <div class="shield-big">${card.icon}</div>
      <div class="shield-type-badge">${card.name} — ${card.subtype.charAt(0).toUpperCase()+card.subtype.slice(1)}</div>
      <div class="ov-title" style="margin:0">${playerName} raised a shield!</div>
      <div class="shield-set-desc">${card.desc}</div>
    </div>
  `);
  setTimeout(() => forceHide(), 2600);
});

// Shield blocked!
socket.on('shieldblocked', ({ playerName, effect, icon, subtype }) => {
  const subtypeLabel = subtype ? subtype.charAt(0).toUpperCase()+subtype.slice(1) : '';
  showOv(`
    <div class="shield-blast-wrap">
      <div class="shield-big">${icon || '🛡️'}</div>
      <div class="shield-type-badge">SHIELD ACTIVATED!</div>
      <div class="ov-title" style="margin:0">${playerName}'s shield fired!</div>
      <div class="shield-effect">${effect}</div>
    </div>
  `);
  // Don't auto-close — will close when next state arrives
});

// Wild
socket.on('wildresolve', ({ card, msg }) => {
  if (card.subtype === 'peek' && !ovPeek) {
    // partner side (non-peeker)
    showOv(`<div class="ov-icon">👀</div><div class="ov-title">Peek!</div><div class="wild-effect">${msg}</div>`);
    setTimeout(() => forceHide(), 5400);
    return;
  }
  if (card.subtype !== 'peek') {
    showOv(`<div class="ov-icon">${card.icon}</div><div class="ov-title">Wild Card!</div><div class="wild-effect">${msg}</div>`);
    setTimeout(() => forceHide(), 2600);
  }
});

socket.on('peek', ({ hand }) => {
  ovPeek = true;
  const cards = hand.map(c=>`<div class="mini-card ${c.type}">${c.icon} ${c.name}</div>`).join('');
  let s = 5;
  showOv(`
    <div class="ov-icon">👀</div>
    <div class="ov-title">Peeking at partner's hand!</div>
    <div class="peek-hand">${cards}</div>
    <div class="peek-timer" id="peek-s">5</div>
  `);
  peekIv = setInterval(()=>{
    s--; const el=document.getElementById('peek-s'); if(el) el.textContent=s;
    if(s<=0){clearInterval(peekIv);peekIv=null;ovPeek=false;forceHide();}
  },1000);
});

// RPS
socket.on('rpsstart', ({ card }) => {
  ovNeedsInput = true;
  showOv(`
    <div class="ov-icon">✊</div>
    <div class="ov-title">Rock Paper Scissors!</div>
    <div class="ov-sub">Pick secretly — winner gets 2 pts!</div>
    <div class="rps-phase-pick">
      <div class="rps-row">
        <button class="rps-btn" onclick="pickRPS('rock')" id="rps-rock">✊</button>
        <button class="rps-btn" onclick="pickRPS('paper')" id="rps-paper">✋</button>
        <button class="rps-btn" onclick="pickRPS('scissors')" id="rps-scissors">✌️</button>
      </div>
    </div>
    <div id="rps-status" style="font-size:13px;color:var(--gray);min-height:18px"></div>
  `);
});

socket.on('rps_opponent_chose', () => {
  const s = document.getElementById('rps-status');
  if (s) s.textContent = '✅ Partner has chosen!';
});

socket.on('rpsresult', ({ choices, names, winnerId, winnerName }) => {
  ovNeedsInput = false;
  const emojis = { rock:'✊', paper:'✋', scissors:'✌️' };
  const [id0, id1] = Object.keys(choices);
  const isWinner = winnerId === socket.id;
  const label = winnerId ? `🏆 ${winnerName} wins +2 pts!` : "🤝 It's a tie!";
  const cls = !winnerId ? 'rb-tie' : isWinner ? 'rb-win' : 'rb-loss';

  // Run countdown then reveal
  let count = 3;
  showOv(`<div class="ov-icon">✊✋✌️</div><div class="ov-title">Revealing in...</div><div class="rps-countdown" id="rps-cd">3</div>`);

  const cdIv = setInterval(() => {
    count--;
    const el = document.getElementById('rps-cd');
    if (count > 0) {
      if (el) { el.textContent = count; el.style.animation='none'; void el.offsetHeight; el.style.animation=''; }
    } else {
      clearInterval(cdIv);
      // Reveal!
      const p0Glow = (id0 === winnerId) ? ' rps-winner-glow' : '';
      const p1Glow = (id1 === winnerId) ? ' rps-winner-glow' : '';
      showOv(`
        <div class="ov-title">Reveal!</div>
        <div class="rps-vs-row">
          <div class="rps-player-col">
            <div class="rps-choice-reveal${p0Glow}">${emojis[choices[id0]]}</div>
            <div class="rps-player-name">${names[id0]}</div>
          </div>
          <div class="rps-vs-label">vs</div>
          <div class="rps-player-col">
            <div class="rps-choice-reveal${p1Glow}">${emojis[choices[id1]]}</div>
            <div class="rps-player-name">${names[id1]}</div>
          </div>
        </div>
        <div class="result-badge ${cls}">${label}</div>
      `);
      setTimeout(() => forceHide(), 3000);
    }
  }, 600);
});

// Tug of War
socket.on('tugstart', ({ card, duration }) => {
  ovNeedsInput = true;
  tugEnded = false;
  let secsLeft = Math.ceil(duration / 1000);
  const CIRC = 163; // 2π*26

  showOv(`
    <div class="ov-icon">🪢</div>
    <div class="ov-title">Tug of War!</div>
    <div class="ov-sub">Tap as fast as you can! Most taps in ${secsLeft}s wins 2 pts!</div>
    <div class="tug-header">
      <span style="color:var(--pink)" id="tug-name-me">${gs.myName}</span>
      <span id="tug-name-op" style="color:#6366f1">${gs.opName}</span>
    </div>
    <div class="tug-scene">
      <div class="tug-rope" id="tug-rope">
        <div class="tug-zone-me" id="tug-zone-me" style="width:50%"></div>
        <div class="tug-zone-op" id="tug-zone-op" style="width:50%"></div>
        <div class="tug-knot" id="tug-knot" style="left:50%">🪢</div>
      </div>
    </div>
    <div class="tug-players-row">
      <div class="tug-player-info">
        <div class="tug-clicks" id="tug-me-clicks">0</div>
        <div class="tug-player-name">taps</div>
      </div>
      <div class="tug-timer-ring">
        <svg class="tug-timer-svg" viewBox="0 0 54 54">
          <circle class="tug-timer-bg" cx="27" cy="27" r="26"/>
          <circle class="tug-timer-arc" id="tug-arc" cx="27" cy="27" r="26"/>
        </svg>
        <span class="tug-timer-num" id="tug-sec">${secsLeft}</span>
      </div>
      <div class="tug-player-info">
        <div class="tug-clicks op" id="tug-op-clicks">0</div>
        <div class="tug-player-name">taps</div>
      </div>
    </div>
    <button class="tug-pull-btn" id="tug-btn" ontouchstart="doTug(event)" onclick="doTug()">💪 PULL!</button>
  `);

  // Countdown timer
  const started = Date.now();
  tugIv = setInterval(() => {
    const elapsed = (Date.now() - started) / 1000;
    const remaining = Math.max(0, duration / 1000 - elapsed);
    const el = document.getElementById('tug-sec');
    const arc = document.getElementById('tug-arc');
    if (el) el.textContent = Math.ceil(remaining);
    if (arc) arc.style.strokeDashoffset = CIRC * (1 - remaining / (duration/1000));
    if (remaining <= 0) { clearInterval(tugIv); tugIv = null; }
  }, 200);
});

socket.on('tugupdate', ({ p0id, p1id, c0, c1 }) => {
  const myId = socket.id;
  const iAmP0 = (myId === p0id);
  const myClicks = iAmP0 ? c0 : c1;
  const opClicks = iAmP0 ? c1 : c0;
  const MAX = 35;
  // Position: positive = I'm winning, negative = they're winning
  const pos = myClicks - opClicks; // from my perspective
  // knot: 50% when tied, <50% when I'm losing, >50% when I'm winning? 
  // Let's say: knot moves to LEFT (0%) as I win more
  // Left = 50% - (pos / MAX) * 50%
  const knotPct = Math.max(5, Math.min(95, 50 - (pos / MAX) * 50));

  const knot = document.getElementById('tug-knot');
  const zoneMe = document.getElementById('tug-zone-me');
  const zoneOp = document.getElementById('tug-zone-op');
  const meEl = document.getElementById('tug-me-clicks');
  const opEl = document.getElementById('tug-op-clicks');

  if (knot) knot.style.left = knotPct + '%';
  if (zoneMe) zoneMe.style.width = knotPct + '%';
  if (zoneOp) zoneOp.style.width = (100 - knotPct) + '%';
  if (meEl) meEl.textContent = myClicks;
  if (opEl) opEl.textContent = opClicks;
});

socket.on('tugresult', ({ winnerId, winnerName, clicks, names }) => {
  if (tugIv) { clearInterval(tugIv); tugIv = null; }
  tugEnded = true;
  ovNeedsInput = false;
  const isMe = winnerId === socket.id;
  const [id0, id1] = Object.keys(names);
  const label = winnerId ? `🏆 ${winnerName} wins +2 pts!` : "🤝 Tied — no points!";
  const cls = !winnerId ? 'rb-tie' : isMe ? 'rb-win' : 'rb-loss';
  const btn = document.getElementById('tug-btn');
  if (btn) btn.disabled = true;

  showOv(`
    <div class="ov-icon">${isMe ? '🏆' : (winnerId ? '😅' : '🤝')}</div>
    <div class="ov-title">${isMe ? 'You pulled harder!' : (winnerId ? `${winnerName} wins!` : 'Tie!')}</div>
    <div class="tug-players-row" style="width:100%;justify-content:center;gap:28px">
      <div class="tug-player-info">
        <div class="tug-clicks">${clicks[id0]||0}</div>
        <div class="tug-player-name">${names[id0]} taps</div>
      </div>
      <div class="tug-player-info">
        <div class="tug-clicks op">${clicks[id1]||0}</div>
        <div class="tug-player-name">${names[id1]} taps</div>
      </div>
    </div>
    <div class="result-badge ${cls}">${label}</div>
  `);
  setTimeout(() => forceHide(), 3000);
});

// Game over
socket.on('gameover', ({ winner, winnerId }) => {
  forceHide();
  const isMe = winnerId === socket.id;
  setText('win-emoji', isMe ? '🏆' : '💌');
  document.getElementById('win-emoji').textContent = isMe ? '🏆' : '💌';
  setText('win-title', isMe ? `You won, ${winner}! 🎉` : `${winner} wins! 🎊`);
  setText('win-sub', isMe ? 'You pick the next activity, love! 💕' : 'The winner picks the next activity! 💕');
  document.getElementById('score-cards').innerHTML = `
    <div class="sc ${gs.myScore>=gs.opScore?'winner':''}">
      <div class="sc-name">${gs.myName}</div><div class="sc-val">${gs.myScore}</div>
    </div>
    <div class="sc ${gs.opScore>gs.myScore?'winner':''}">
      <div class="sc-name">${gs.opName}</div><div class="sc-val">${gs.opScore}</div>
    </div>`;
  show('screen-over');
});

socket.on('partnerleft', ({ name }) => {
  forceHide();
  toast(`💔 ${name} disconnected. Waiting to reconnect...`, 6000);
});

// ── User actions ──────────────────────────────────────────────────────────────
function getName() {
  const n = document.getElementById('name-in').value.trim();
  if (!n) { document.getElementById('home-err').textContent = 'Please enter your name!'; return null; }
  return n;
}
document.getElementById('create-btn').onclick = () => {
  const n = getName(); if (!n) return;
  socket.emit('create', { name: n });
};
document.getElementById('join-btn').onclick = () => {
  const n = getName(); if (!n) return;
  const code = document.getElementById('code-in').value.trim().toUpperCase();
  if (code.length < 4) { document.getElementById('home-err').textContent = 'Enter the 4-letter room code!'; return; }
  socket.emit('join', { name: n, code });
};
document.getElementById('name-in').onkeydown = e => { if(e.key==='Enter') document.getElementById('create-btn').click(); };
document.getElementById('code-in').onkeydown = e => { if(e.key==='Enter') document.getElementById('join-btn').click(); };
document.getElementById('play-btn').onclick = () => {
  if (!selectedCard || !gs.isMyTurn) return;
  socket.emit('play', { id: selectedCard });
  selectedCard = null; updatePlayBtn();
};

// Overlay callbacks
function doJudge(correct) { ovNeedsInput = false; socket.emit('judge', { correct }); }
function submitAns() {
  const el = document.getElementById('ans-in');
  if (!el?.value.trim()) { toast('Type your answer first!'); return; }
  socket.emit('memoryanswer', { answer: el.value.trim() });
  el.disabled = true;
  const btn = document.querySelector('#ov-box .ov-btn');
  if (btn) { btn.disabled = true; btn.textContent = '✓ Answer sent!'; }
}
function pickRPS(choice) {
  socket.emit('rpschoice', { choice });
  ['rock','paper','scissors'].forEach(c => {
    const b = document.getElementById(`rps-${c}`);
    if (b) { b.disabled = true; if(c===choice) b.classList.add('chosen'); }
  });
  const s = document.getElementById('rps-status');
  if (s) s.innerHTML = `<span class="rps-waiting">⏳ Waiting for ${gs.opName}...</span>`;
}
function doTug(e) {
  if (e) { e.preventDefault(); e.stopPropagation(); }
  if (tugEnded) return;
  socket.emit('tugclick');
  const btn = document.getElementById('tug-btn');
  if (btn) { btn.style.transform = 'scale(.93)'; setTimeout(() => { if(btn) btn.style.transform=''; }, 80); }
}
</script>
